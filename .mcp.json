{
	"mcpServers": {
		"svelte": {
			"type": "stdio",
			"command": "pnpm",
			"args": ["exec", "svelte-mcp"]
		},
		"tailwind": {
			"type": "stdio",
			"command": "pnpm",
			"args": ["dlx", "-y", "@modelcontextprotocol/server-tailwindcss"]
		},
		"postgres": {
			"type": "stdio",
			"command": "pnpm",
			"args": ["dlx", "-y", "@modelcontextprotocol/server-postgres"]
		}
	}
}
